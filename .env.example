# === App ===
APP_ENV=development
PROJECT_NAME="AI Anime Companion"
VERSION="1.0.0"
DEBUG=False

# === Database ===
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/anime_companion

# === Docker Compose DB ===
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=anime_companion

# === Redis ===
REDIS_URL=redis://redis:6379/0

# === JWT ===
# Generate with: openssl rand -hex 32 (REQUIRED — no default provided)
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32

# === Internal Services ===
AGENT_SERVICE_URL=http://agent-service:8001
GAME_SERVICE_URL=http://game-service:8002

# === LLM APIs (ít nhất một key để agent trả lời bằng LLM; không set thì dùng reply mặc định) ===
OPENAI_API_KEY=sk-your-key-here
# GROQ_API_KEY=your-groq-key-here
GOOGLE_API_KEY=your-gemini-key-here

# === Web search (Option A - Tavily) ===
# ENABLE_WEB_SEARCH=true
# TAVILY_API_KEY=tvly-your-key-here
# TAVILY_SEARCH_DEPTH=basic   # basic|advanced

# === Wikipedia search (Option B) ===
# ENABLE_WIKI_SEARCH=true
# WIKI_LANG=vi   # vi|en|ja|...
# DEBUG_WIKI_SEARCH=false

# === AniList search (anime/manga database) ===
# ENABLE_ANILIST=true
# DEBUG_ANILIST=false

# === Community search (Option C: Reddit/FanWiki) ===
# ENABLE_COMMUNITY_SEARCH=true
# COMMUNITY_INCLUDE_DOMAINS=reddit.com,fandom.com,wiki.gg
# DEBUG_COMMUNITY_SEARCH=false

# === Knowledge judge (hybrid reasoning verifier) ===
# ENABLE_KNOWLEDGE_JUDGE=true

# === Intent: hybrid = model/keyword + Groq reason, lấy kết quả ổn hơn ===
# ENABLE_INTENT_GROQ_HYBRID=true

# === Intent model (optional — Llama+PEFT; nếu không set thì dùng keyword) ===
# INTENT_MODEL_PATH=services/agent-service/models/intent
# ENABLE_INTENT_MODEL_RUNTIME=true
# INTENT_BASE_MODEL=unsloth/llama-3-8b-Instruct-bnb-4bit

# === RAG ===
CHROMA_HOST=chromadb
CHROMA_PORT=8000

# === Translation ===
# NLLB_MODEL_PATH=./models/nllb-200
# GOOGLE_TRANSLATE_API_KEY=your-key-here

# === MLflow ===
MLFLOW_TRACKING_URI=http://mlflow:5000
