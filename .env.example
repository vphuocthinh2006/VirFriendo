# Copy to `.env` locally. Safe to commit: placeholders only — never put real API keys or production passwords here.
# (Real secrets belong in `.env`, which is gitignored.)

# === App ===
APP_ENV=development
PROJECT_NAME="AI Anime Companion"
VERSION="1.0.0"
DEBUG=False

# === HTTP security (backend) ===
# Comma-separated browser origins allowed to call API with cookies / Authorization (no wildcard).
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# production: comma-separated API hostnames only (no https://), e.g. api.example.com
# TRUSTED_HOSTS=api.example.com

# === Database (local dev example — change user/password/db name) ===
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@localhost:5432/DB_NAME

# === Docker Compose DB ===
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=anime_companion

# === Redis ===
REDIS_URL=redis://redis:6379/0

# === JWT ===
# Generate with: openssl rand -hex 32
SECRET_KEY=change-me-use-openssl-rand-hex-32

# === Internal Services ===
AGENT_SERVICE_URL=http://agent-service:8001
GAME_SERVICE_URL=http://game-service:8002

# === LLM APIs ===
OPENAI_API_KEY=
LLM_PROVIDER=openai   # openai|groq
# GROQ_API_KEY=

# === OAuth (optional) ===
# GOOGLE_CLIENT_ID=

# === Web search (optional) ===
# ENABLE_WEB_SEARCH=true
# TAVILY_API_KEY=

# === RAG ===
CHROMA_HOST=chromadb
CHROMA_PORT=8000

# === MLflow ===
MLFLOW_TRACKING_URI=http://mlflow:5000
