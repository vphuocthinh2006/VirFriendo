# Copy to .env locally (never commit .env). This file is a template only — no real secrets.
#
# Backend API: leave empty in dev — Vite proxy forwards /auth, /chat, /game, /agents, /diary → localhost:8000
# Or set explicitly: http://localhost:8000
# Production: https://your-api.example.com
VITE_API_URL=

# Google OAuth Web Client ID (create in Google Cloud Console; OAuth 2.0 Client IDs)
VITE_GOOGLE_CLIENT_ID=
